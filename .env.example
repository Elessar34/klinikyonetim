# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/railway?schema=public"

# NextAuth.js
NEXTAUTH_URL="https://klinikyonetim.net"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# App Config
NEXT_PUBLIC_APP_NAME="Klinik Yönetim"
NEXT_PUBLIC_APP_URL="https://klinikyonetim.net"
NEXT_PUBLIC_ROOT_DOMAIN="klinikyonetim.net"

# iyzico (Payment - optional)
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Email (Resend - optional)
RESEND_API_KEY=""

# SMS (NetGSM - optional)
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_MSGHEADER=""

# Cloudflare R2 (File Storage - optional)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Cron Jobs Security
CRON_SECRET=""
